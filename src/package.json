{
    "name": "cic",
    "version": "1.0.0",
    "description": "OneLogin CIC CRI",
    "repository": "https://github.com/govuk-one-login/ipv-cri-cic-api",
    "author": "GDS",
    "license": "MIT",
    "dependencies": {
        "@aws-lambda-powertools/logger": "1.5.1",
        "@aws-lambda-powertools/metrics": "1.5.1",
        "@aws-sdk/client-dynamodb": "3.1045.0",
        "@aws-sdk/client-kms": "3.1045.0",
        "@aws-sdk/client-s3": "3.1045.0",
        "@aws-sdk/client-sqs": "3.1045.0",
        "@aws-sdk/credential-providers": "3.1045.0",
        "@aws-sdk/lib-dynamodb": "3.1045.0",
        "@smithy/node-http-handler": "4.0.4",
        "ajv": "8.20.0",
        "aws-xray-sdk-core": "3.10.3",
        "axios": "1.16.0",
        "body-parser": "2.2.2",
        "class-validator": "0.14.1",
        "dotenv-cli": "11.0.0",
        "ecdsa-sig-formatter": "1.0.11",
        "esbuild": "0.25.2",
        "jose": "6.2.3"
    },
    "scripts": {
        "unit": "./node_modules/.bin/vitest run tests/unit/ --reporter=default",
        "test:unit": "npm run compile && npm run unit",
        "lint:fix": "eslint --fix --output-file ./reports/eslint/report.html --format html -c eslint.config.mjs --ext *.ts .",
        "compile": "./node_modules/.bin/tsc",
        "lint": "eslint -c eslint.config.mjs *.ts .",
        "test:e2e": "./node_modules/.bin/vitest run tests/api/e2e*.test.ts --reporter=default --reporter=junit --outputFile.junit=results/e2e-report.xml",
        "test:infra": "./node_modules/.bin/vitest run tests/infra/  --reporter=default",
        "api": "./node_modules/.bin/vitest run tests/api/ --reporter=default",
        "test:api": "npm run compile && npm run api",
        "test:pii": "bash ./check-logs.sh",
        "kill:dynamodblocal": "cd tests/contract; ./scripts/kill-dynamodb-local.sh",
        "start:dynamodblocal": "cd tests/contract; ./scripts/setup-dynamodb-local.sh",
        "test:pactconnection": "cd tests/contract; ./scripts/test-pact-connection.sh",
        "start:contract": "npm run start:dynamodblocal && npm run test:pactconnection && npm run wait-start:contract",
        "wait-start:contract": "wait-on tcp:127.0.0.1:8000 && cd tests/contract && tsx ./app.ts",
        "test:provider": "./node_modules/.bin/vitest run tests/contract/CicCriProvider.test.ts --reporter=default",
        "test:contract": "wait-on tcp:127.0.0.1:3000; cd tests/contract; npm run test:provider && npm run kill:dynamodblocal",
        "test:contract:ci": "dotenv -e.env.contract -- bash -c 'npm run start:contract & npm run test:contract && kill $!'"
    },
    "devDependencies": {
        "@types/aws-lambda": "8.10.161",
        "@types/express": "4.17.21",
        "@types/js-yaml": "4.0.9",
        "@types/node": "20.14.8",
        "@typescript-eslint/eslint-plugin": "8.56.1",
        "@typescript-eslint/parser": "8.56.1",
        "@vitest/coverage-v8": "4.1.4",
        "aws-cdk-lib": "2.253.1",
        "aws-sdk-client-mock": "4.1.0",
        "dotenv": "17.2.2",
        "eslint": "10.0.2",
        "fast-xml-parser": "5.7.3",
        "vitest": "4.1.4",
        "vitest-mock-extended": "4.0.0",
        "typescript": "4.9.5",
        "wait-on": "9.0.10",
        "yaml-cfn": "0.3.2",
        "aws4-axios": "3.4.0",
        "@pact-foundation/pact": "12.1.3",
        "express": "4.22.1",
        "tsx": "4.21.0",
        "express-asyncify": "2.1.2"
    },
    "engines": {
        "node": "22.*"
    },
    "overrides": {
        "form-data": ">=4.0.4"
    },
    "type": "module"
}
