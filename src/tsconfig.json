{
  "compilerOptions": {
    "experimentalDecorators": true,
    "target": "es2022",
    "strict": true,
    "preserveConstEnums": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./build/",
    "module": "es2022",
    "types": [
      "node"
    ]
  },
  "exclude": [
    "node_modules",
    "tests",
    "vitest.config.ts",
    "vitest.setup.ts"
  ]
}
